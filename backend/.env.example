# Copy to .env and customise. NEVER commit a real .env.
# These values are read at container start (see docker-compose.yml).

# --- Data sources ---------------------------------------------------------
DB_PATH=/app/data/reach.db
EXCEL_PATH=/data_sources/Dami Action_MAIN1.xlsx
SHP_NGA=/data_sources/gadm41_NGA_shp
SHP_NER=/data_sources/gadm41_NER_shp
SHP_MLI=/data_sources/gadm41_MLI_shp

# --- Ingestion ------------------------------------------------------------
# Set 1 to nuke and re-ingest on next container start.
FORCE_REINGEST=0

# --- CORS -----------------------------------------------------------------
# Comma-separated allowed origins. Use the public origin in prod.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Authentication -------------------------------------------------------
# Set 1 to bypass auth entirely (dev only). DO NOT set this in production.
REACH_AUTH_OPTIONAL=0

# Preferred: JSON object of { "username": "<bcrypt-hash>" }. Generate hashes via:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'PASS', bcrypt.gensalt(12)).decode())"
# Example (do not use these credentials):
# REACH_USERS_JSON={"admin":"$2b$12$abcdefghijklmnopqrstuvwxyz0123456789ABCDEFGH"}

# Fallback single-user pair (used only if REACH_USERS_JSON is unset).
REACH_USER=admin
REACH_PASS=reach2026

# CHANGE THIS IN PRODUCTION. HMAC key for signing bearer tokens.
REACH_SECRET=please-replace-with-32-bytes-of-randomness

# Token lifetime in seconds (default 8 hours).
REACH_TOKEN_TTL=28800

# Refresh grace window — how long after expiry /auth/refresh stays valid.
REACH_REFRESH_GRACE=3600

# Login rate-limit (per IP+username).
REACH_LOGIN_MAX=8
REACH_LOGIN_WINDOW=600
